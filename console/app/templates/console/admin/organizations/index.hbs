{{page-title (t "console.admin.organizations.index.title")}}
{{! template-lint-disable no-unbound }}

<Layout::Resource::Tabular
    @resource="company"
    @title={{t "console.admin.organizations.index.title"}}
    @searchQuery={{unbound this.query}}
    @onSearch={{this.search}}
    @data={{@model}}
    @columns={{this.columns}}
    @page={{this.page}}
    @onPageChange={{fn (mut this.page)}}
    @setupTable={{fn (mut this.table)}}
    @actionButtons={{this.actionButtons}}
    @bulkActions={{this.bulkActions}}
    @controller={{this}}
    @selectable={{true}}
    @canSelectAll={{true}}
    @onRowClick={{this.goToCompany}}
    @searchInputClass="admin-organization-resource-search"
    @filterPickerButtonClass="admin-organization-resource-action-button"
    @columnPickerButtonClass="admin-organization-resource-action-button"
    @emptyStateComponent={{component
        "table/empty-state"
        variant="compact"
        icon="building"
        title="No organizations found"
        description="No organizations match the current admin view."
        filteredTitle="No organizations match your filters"
        filteredDescription="Adjust the search, filters, or saved view to find another organization."
        primaryText="Clear View"
        primaryIcon="filter-circle-xmark"
        primaryAction=this.clearSavedView
    }}
/>

{{outlet}}
