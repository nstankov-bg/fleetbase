{{page-title "Activity"}}

<div class="mx-auto flex w-full max-w-7xl flex-col gap-4 p-4 md:p-6">
    <div class="flex flex-col gap-1">
        <h2 class="text-base font-bold text-gray-900 dark:text-gray-100">Activity Stream</h2>
        <p class="text-sm text-gray-500 dark:text-gray-300">Review organization-wide activity captured for this company UUID.</p>
    </div>

    <RegistryYield @registry="console:admin:organization:activity" @context={{hash organization=@model}} as |RegistryComponent context|>
        <RegistryComponent @organization={{context.organization}} />
    </RegistryYield>

    <section class="overflow-hidden rounded-md border bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <ActivityLog
            @companyUuid={{@model.uuid}}
            @showBadges={{true}}
            @headerWrapperClass="border-b border-gray-200 px-4 py-3 dark:border-gray-700"
            class="p-4"
        />
    </section>
</div>
